#Task 3 Sentiment Analysis

library(tm)
library(SnowballC)
library(wordcloud)

#loading files containing online reviews on Superman (2025)

text = readLines("C:/Users/User/OneDrive/Desktop/Unstructured Data/Project 1/Part 2/Reviews based on engagement, number.txt")

#Loading the file as a corpus

docs = Corpus(VectorSource(text))
inspect(docs)

# Replace special characters with space
toSpace <- content_transformer(function(x, pattern) gsub(pattern, " ", x))
docs <- tm_map(docs, toSpace, "/")
docs <- tm_map(docs, toSpace, "@")
docs <- tm_map(docs, toSpace, "\\|")

# Clean the text
docs <- tm_map(docs, content_transformer(tolower))   # lowercase
docs <- tm_map(docs, removeNumbers)                  # remove numbers
docs <- tm_map(docs, removeWords, stopwords("english"))  # remove stopwords
docs <- tm_map(docs, removePunctuation)              # remove punctuation
docs <- tm_map(docs, stripWhitespace)                # remove extra spaces
docs <- tm_map(docs, stemDocument)                   # stemming

# Build term document matrix
dtm <- TermDocumentMatrix(docs)
m <- as.matrix(dtm)
v <- sort(rowSums(m), decreasing = TRUE)
d <- data.frame(word = names(v), freq = v)

# Preview top words
head(d, 10)

#Sentiment scoring using different lexicons
library(syuzhet)

# Get sentiment scores using 4 different methods
syuzhet_vector <- get_sentiment(text, method="syuzhet")
bing_vector <- get_sentiment(text, method="bing")
afinn_vector <- get_sentiment(text, method="afinn")
nrc_vector <- get_sentiment(text, method="nrc")

# View summaries
summary(syuzhet_vector)
summary(bing_vector)
summary(afinn_vector)
summary(nrc_vector)

# Compare all three side by side
rbind(
  sign(head(syuzhet_vector)),
  sign(head(bing_vector)),
  sign(head(afinn_vector))
)
