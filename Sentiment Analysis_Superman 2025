# Custom dictionary sentiment analysis
m <- d$word  # using your already cleaned word list

mysentiment <- function(m)
{
  mydictpos = c("good", "great", "love", "terrif", "amaz", 
                "delight", "fun", "brilliant", "perfect", "best")
  
  mydictneg = c("bad", "ugly", "lazy", "worst", "bore", 
                "disappoint", "mess", "hate", "poor", "weak")
  
  pos_score = sum(!is.na(match(m, mydictpos)))
  neg_score = (-1)*sum(!is.na(match(m, mydictneg)))
  sentiment_score = pos_score + neg_score
  sentiment_score
}

mysentiment(m)


