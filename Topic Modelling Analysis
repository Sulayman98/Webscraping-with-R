ap_documents_5 <- tidy(lda_5, matrix = "gamma")

ap_documents_5 %>%
  ggplot(aes(factor(topic), gamma)) +
  geom_boxplot() +
  labs(title = "Document-Topic Probabilities (5 Topics)",
       x = "Topic", y = "Gamma")

#Running the Beta spread
beta_spread <- ap_topics %>% 
  mutate(topic = paste0("topic", topic)) %>% 
  spread(topic, beta) %>% 
  filter(topic1 > .001 | topic2 > .001) %>% 
  mutate(log_ratio = log2(topic2 / topic1))

beta_spread %>% 
  mutate(term = reorder(term, log_ratio)) %>% 
  ggplot(aes(term, log_ratio)) +
  geom_col(show.legend = FALSE) +
  coord_flip()

beta_spread %>%
  group_by(direction = ifelse(log_ratio > 0, "Finance", "Football")) %>%
  top_n(20, abs(log_ratio)) %>%
  ungroup() %>%
  mutate(term = reorder(term, log_ratio)) %>%
  ggplot(aes(term, log_ratio)) +
  geom_col(show.legend = FALSE) +
  coord_flip() +
  labs(title = "Words with greatest difference between topics",
       x = "Term", y = "Log ratio (Finance vs Football)")


